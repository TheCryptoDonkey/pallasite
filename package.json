{
  "name": "@thecryptodonkey/pallasite",
  "version": "0.1.0",
  "description": "Pallasite — Shoot rocks. Stack sats. Cosmic arcade Asteroids with Lightning payouts and Nostr leaderboards. Sign in with Nostr.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm run sync-sdk && vite",
    "build": "pnpm run sync-sdk && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx tools/run-harnesses.ts",
    "test:e2e": "tsx tools/run-e2e.ts",
    "test:lobby": "tsx tools/run-lobby-e2e.ts",
    "test:render": "tsx tools/run-render-e2e.ts",
    "test:solar": "tsx tools/run-solar-visual-qa.ts",
    "test:install": "playwright install chromium",
    "record:duel": "tsx tools/record-duel.ts",
    "hunt:desync": "tsx tools/run-desync-hunter.ts",
    "test:spectate-latejoin": "tsx tools/run-spectate-latejoin-e2e.ts",
    "test:coop-campaign": "tsx tools/run-coop-campaign-e2e.ts",
    "test:deathmatch:nplayer": "tsx tools/run-deathmatch-nplayer-e2e.ts",
    "test:deathmatch:soak": "tsx tools/run-deathmatch-soak.ts",
    "scale:deathmatch": "tsx tools/run-deathmatch-scale.ts",
    "check:prod:playability": "tsx tools/check-prod-playability.ts",
    "check:prod:multiplayer": "tsx tools/check-prod-multiplayer.ts",
    "record:solar": "tsx tools/record-solar-qa.ts",
    "sync-sdk": "if [ -f ../signet-login/dist/signet-login.iife.js ]; then cp ../signet-login/dist/signet-login.iife.js public/signet-login.iife.js; else echo 'sync-sdk: signet-login sibling not present, using committed copy'; fi",
    "gen-backgrounds": "tsx tools/generate-backgrounds.ts",
    "optimise-backgrounds": "tsx tools/optimise-backgrounds.ts",
    "gen-logo": "tsx tools/generate-logo.ts"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "jsqr": "^1.4.0",
    "nostr-veil": "^0.8.4",
    "qrcode": "^1.5.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.184.1",
    "playwright": "^1.48.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCryptoDonkey/pallasite.git"
  }
}
