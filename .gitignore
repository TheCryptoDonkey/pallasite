# Dependencies
node_modules/

# Build output
dist/

# Music masters — keep locally, never commit. The compressed opus versions in
# public/music/ ARE tracked and ship with the build; the WAV originals + any
# DAW exports stay on disk only. ~600MB total, would bloat the repo permanently.
/music/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env
.env
.env.local
.env.*.local

# Build cache
*.tsbuildinfo
.cache/

# Local dev harnesses. determinism / lockstep / peer / regression / rollback
# harnesses are tracked (they're load-bearing for multiplayer + B3 work);
# anything else following the *-harness.html naming is local experimentation
# and stays out.
*-harness.html
!determinism-harness.html
!lockstep-harness.html
!peer-harness.html
!regression-harness.html
!rollback-harness.html

# Duel recorder output (tools/record-duel.ts writes the spectator's video
# here as a .webm chunk + transcodes to duel-demo.mp4). Local artefacts;
# we don't ship them in the repo.
/tools/record-out/
